@* 

@model IEnumerable<OnlineTicketsSystem.Models.City>

<li>
    <a class="dropdown-item fw-bold"
       asp-controller="Cities"
       asp-action="Index">
        Всички градове
    </a>
</li>

<li><hr class="dropdown-divider" /></li>

@foreach (var city in Model)
{
    <li>
        <a class="dropdown-item"
           asp-controller="Cities"
           asp-action="ByCity"
           asp-route-slug="@city.Slug">
            @city.Name
        </a>
    </li>
}



 *@
@model OnlineTicketsSystem.ViewModels.CitiesMenuVm

<li class="nav-item dropdown">
    <a class="nav-link dropdown-toggle text-dark"
       href="#"
       id="citiesDropdown"
       role="button"
       data-bs-toggle="dropdown"
       aria-expanded="false">
        Градове
    </a>

    <div class="dropdown-menu p-3" aria-labelledby="citiesDropdown" style="min-width: 720px; max-width: 90vw;">
        <div class="row g-3">

            <div class="col-4">
                <div class="fw-bold mb-2">Области</div>
                <div class="list-group" style="max-height: 320px; overflow:auto;">
                    @for (int i = 0; i < Model.Regions.Count; i++)
                    {
                        var r = Model.Regions[i];
                        <button type="button"
                                class="list-group-item list-group-item-action region-btn @(i == 0 ? "active" : "")"
                                data-region="@r">
                            @r
                        </button>
                    }
                </div>
            </div>

            <div class="col-8">
                <div class="fw-bold mb-2">Градове</div>

                @for (int i = 0; i < Model.Regions.Count; i++)
                {
                    var r = Model.Regions[i];
                    var cities = Model.CitiesByRegion.ContainsKey(r) ? Model.CitiesByRegion[r] : new List<OnlineTicketsSystem.ViewModels.CityMenuItemVm>();

                    <div class="cities-panel" data-region="@r" style="display:@(i == 0 ? "block" : "none"); max-height: 320px; overflow:auto;">
                        <div class="row">
                            @foreach (var c in cities)
                            {
                                <div class="col-6">
                                    <a class="dropdown-item"
                                       asp-controller="Cities"
                                       asp-action="ByCity"
                                       asp-route-slug="@c.Slug">
                                        @c.Name
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

        </div>
    </div>
</li>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const root = document.getElementById("citiesDropdown")?.closest(".dropdown");
        if (!root) return;

        const buttons = root.querySelectorAll(".region-btn");
        const panels = root.querySelectorAll(".cities-panel");

        function show(region) {
            panels.forEach(p => p.style.display = (p.dataset.region === region ? "block" : "none"));
            buttons.forEach(b => b.classList.toggle("active", b.dataset.region === region));
        }

        buttons.forEach(b => {
            b.addEventListener("mouseenter", () => show(b.dataset.region));
            b.addEventListener("click", () => show(b.dataset.region));
        });
    });
</script>