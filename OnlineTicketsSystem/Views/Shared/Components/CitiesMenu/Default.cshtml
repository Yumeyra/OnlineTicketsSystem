

@model OnlineTicketsSystem.ViewModels.CitiesMenuVm

<a class="nav-link dropdown-toggle text-dark"
   href="#"
   id="citiesDropdown"
   role="button"
   data-bs-toggle="dropdown"
   aria-expanded="false">
    Градове
</a>

<div class="dropdown-menu p-3" aria-labelledby="citiesDropdown" style="min-width:700px;">
    <div class="row">

        <!-- Regions -->
        <div class="col-4">
            <strong>Области</strong>

            <div class="list-group mt-2">

                @for (int i = 0; i < Model.Regions.Count; i++)
                {
                    var r = Model.Regions[i];

                    <button class="list-group-item list-group-item-action region-btn @(i == 0 ? "active" : "")"
                            data-region="@r">
                        @r
                    </button>
                }

            </div>
        </div>

        <!-- Cities -->
        <div class="col-8">

            <strong>Градове</strong>

            @for (int i = 0; i < Model.Regions.Count; i++)
            {
                var r = Model.Regions[i];
                var cities = Model.CitiesByRegion[r];

                <div class="cities-panel mt-2"
                     data-region="@r"
                     style="display:@(i == 0 ? "block" : "none");">

                    <div class="row">

                        @foreach (var c in cities)
                        {
                            <div class="col-6">
                                <a class="dropdown-item"
                                   asp-controller="Cities"
                                   asp-action="ByCity"
                                   asp-route-slug="@c.Slug">
                                    @c.Name
                                </a>
                            </div>
                        }

                    </div>

                </div>
            }

        </div>

    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const regions = document.querySelectorAll(".region-btn");
        const panels = document.querySelectorAll(".cities-panel");

        function show(region) {

            panels.forEach(p => {
                p.style.display = (p.dataset.region === region) ? "block" : "none";
            });

            regions.forEach(r => {
                r.classList.toggle("active", r.dataset.region === region);
            });

        }

        regions.forEach(btn => {

            btn.addEventListener("mouseenter", () => show(btn.dataset.region));
            btn.addEventListener("click", () => show(btn.dataset.region));

        });

    });
</script>