@model OnlineTicketsSystem.ViewModels.EventDetailsViewModel

@{
    ViewData["Title"] = "Детайли за събитие";
    bool isPast = Model.Event.Date.Date < DateTime.Today;
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-info rounded-3 shadow-sm border-0">
        @TempData["Message"]
    </div>
}

<div class="container mt-4 mb-5">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-body p-4 p-lg-5">
            <div class="row g-4 align-items-start">
                <!-- Poster -->
                <div class="col-lg-4 col-md-5">
                    @if (!string.IsNullOrWhiteSpace(Model.Event.ImageUrl))
                    {
                        <img src="@Model.Event.ImageUrl"
                             alt="@Model.Event.Title"
                             class="img-fluid rounded-4 shadow-sm w-100"
                             style="max-height: 520px; object-fit: cover;" />
                    }
                    else
                    {
                        <img src="~/images/placeholder.jpg"
                             alt="No image"
                             class="img-fluid rounded-4 shadow-sm w-100"
                             style="max-height: 520px; object-fit: cover;" />
                    }
                </div>

                <!-- Main info -->
                <div class="col-lg-8 col-md-7">
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                        @if (!string.IsNullOrWhiteSpace(Model.Event.Category?.Name))
                        {
                            <span class="badge rounded-pill bg-primary fs-6 px-3 py-2">
                                @Model.Event.Category.Name
                            </span>
                        }

                        @if (!string.IsNullOrWhiteSpace(Model.Event.City))
                        {
                            <span class="badge rounded-pill bg-secondary fs-6 px-3 py-2">
                                @Model.Event.City
                            </span>
                        }
                    </div>

                    <h1 class="display-5 fw-bold mb-4">@Model.Event.Title</h1>

                    <div class="row g-3 mb-4">
                        <div class="col-sm-6">
                            <div class="p-3 bg-light rounded-4 h-100">
                                <div class="event-info-label">Място</div>
                                <div class="event-info-value">@Model.Event.Venue</div>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="p-3 bg-light rounded-4 h-100">
                                <div class="event-info-label">Дата</div>
                                <div class="event-info-value">@Model.Event.Date.ToString("dd.MM.yyyy")</div>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="p-3 bg-light rounded-4 h-100">
                                <div class="event-info-label">Капацитет</div>
                                <div class="event-info-value">@Model.Event.Capacity</div>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="p-3 bg-light rounded-4 h-100">
                                <div class="event-info-label">Оставащи места</div>
                                <div class="event-info-value">@Model.RemainingSeats</div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="text-muted small mb-1">Цена</div>
                        <div class="fs-2 fw-bold text-success">
                            @Model.Event.Price.ToString("0.00") EUR
                        </div>
                    </div>

                    @if (!isPast)
                    {
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <div class="d-flex flex-wrap align-items-end gap-3">
                                <!-- Buy ticket -->
                                <form asp-controller="Cart" asp-action="Add" method="post" class="d-flex flex-wrap align-items-end gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="eventId" value="@Model.Event.Id" />

                                    <div>
                                        <label for="quantity" class="form-label fw-semibold">Количество</label>
                                        <input type="number"
                                               id="quantity"
                                               name="quantity"
                                               value="1"
                                               min="1"
                                               max="20"
                                               class="form-control rounded-3"
                                               style="width: 120px;" />
                                    </div>

                                    <button type="submit" class="btn btn-warning btn-lg rounded-3 px-4">
                                        Купи билет
                                    </button>
                                </form>

                                <!-- Favorite -->
                                <form asp-controller="Favorites" asp-action="Add" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="eventId" value="@Model.Event.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-lg rounded-3 px-4">
                                        ❤️ Добави в любими
                                    </button>
                                </form>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning border-0 rounded-4 mt-3">
                                <div class="fw-semibold mb-2">
                                    За да закупиш билет или да добавиш събитието в любими, трябва да влезеш или да се регистрираш.
                                </div>
                                <div class="d-flex gap-2 flex-wrap">
                                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-primary rounded-3">
                                        Вход
                                    </a>
                                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-secondary rounded-3">
                                        Регистрация
                                    </a>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-secondary border-0 rounded-4 mt-3">
                            Това събитие вече е минало.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Description -->
    <div class="card border-0 shadow-sm rounded-4 mt-4">
        <div class="card-body p-4">
            <h3 class="fw-bold mb-3">Описание</h3>
            @if (!string.IsNullOrWhiteSpace(Model.Event.Description))
            {
                <p class="mb-0 fs-5">@Model.Event.Description</p>
            }
            else
            {
                <p class="text-muted mb-0">Няма добавено описание за това събитие.</p>
            }
        </div>
    </div>

    <!-- Reviews -->
    <div class="mt-5">
        <h2 class="fw-bold mb-3">Отзиви</h2>

        @if (Model.ReviewsCount == 0)
        {
            <div class="alert alert-light border rounded-4">
                Все още няма отзиви.
            </div>
        }
        else
        {
            <p class="fs-5 mb-4">
                <strong>Средна оценка:</strong> @Model.AverageRating.ToString("0.0") / 5
                <span class="text-muted">(@Model.ReviewsCount отзива)</span>
            </p>

            <div class="d-grid gap-3">
                @foreach (var r in Model.Reviews)
                {
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                <div>
                                    <div class="fw-bold fs-5">@(r.User?.UserName ?? "Потребител")</div>
                                    <div class="text-muted small">
                                        @r.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                    </div>
                                </div>

                                <div class="fs-5 fw-semibold text-warning">
                                    ⭐ @r.Rating / 5
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(r.Comment))
                            {
                                <div class="mt-3">
                                    @r.Comment
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Add review -->
    <div class="mt-5">
        <h2 class="fw-bold mb-3">Остави отзив</h2>

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            if (!Model.CanReview)
            {
                <div class="alert alert-warning rounded-4 border-0">
                    Можеш да оставиш отзив само ако имаш <b>платен билет</b> за това събитие.
                </div>
            }
            else if (Model.UserHasReviewed)
            {
                <div class="alert alert-info rounded-4 border-0">
                    Вече си оставил/а отзив за това събитие.
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <form asp-controller="Reviews" asp-action="Create" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="eventId" value="@Model.Event.Id" />

                            <div class="mb-3">
                                <label class="form-label fw-semibold">Оценка</label>
                                <select name="rating" class="form-select rounded-3" style="max-width: 220px;">
                                    <option value="5">5 - Отлично</option>
                                    <option value="4">4</option>
                                    <option value="3">3</option>
                                    <option value="2">2</option>
                                    <option value="1">1 - Слабо</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold">Коментар (по желание)</label>
                                <textarea name="comment" class="form-control rounded-3" rows="5" maxlength="1000"></textarea>
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg rounded-3 px-4">
                                Публикувай
                            </button>
                        </form>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-warning rounded-4 border-0">
                За да оставиш отзив, трябва да влезеш в профила си.
                <div class="mt-3 d-flex gap-2 flex-wrap">
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-primary rounded-3">
                        Вход
                    </a>
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-secondary rounded-3">
                        Регистрация
                    </a>
                </div>
            </div>
        }
    </div>

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-link text-decoration-none ps-0">
            ← Обратно към всички събития
        </a>
    </div>
</div>