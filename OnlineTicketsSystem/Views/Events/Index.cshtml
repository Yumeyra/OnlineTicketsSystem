<div class="container mt-4 mb-5">
    <div class="mb-4">
        <h1 class="fw-bold mb-2">Събития</h1>
        <p class="text-muted mb-0">Разгледай всички предстоящи и минали събития.</p>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info border-0 rounded-4 shadow-sm mb-4">
            @TempData["Message"]
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <form asp-controller="Events" asp-action="Index" method="get">
                <div class="row g-3">
                    <div class="col-md-6 col-lg-3">
                        <label class="form-label fw-semibold">Търси</label>
                        <input type="text"
                               name="searchTerm"
                               value="@Model.SearchTerm"
                               class="form-control"
                               placeholder="Име, град или място" />
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <label class="form-label fw-semibold">Град</label>
                        <select name="city" class="form-select">
                            <option value="">Всички градове</option>
                            @foreach (var city in Model.Cities)
                            {
                                if (Model.SelectedCity == city)
                                {
                                    <option value="@city" selected>@city</option>
                                }
                                else
                                {
                                    <option value="@city">@city</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <label class="form-label fw-semibold">Категория</label>
                        <select name="category" class="form-select">
                            <option value="">Всички категории</option>
                            @foreach (var category in Model.Categories)
                            {
                                if (Model.SelectedCategory == category)
                                {
                                    <option value="@category" selected>@category</option>
                                }
                                else
                                {
                                    <option value="@category">@category</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <label class="form-label fw-semibold">Дата</label>
                        <input type="date"
                               name="date"
                               value="@(Model.SelectedDate?.ToString("yyyy-MM-dd"))"
                               class="form-control" />
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-4">
                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                        Филтрирай
                    </button>

                    <a asp-controller="Events"
                       asp-action="Index"
                       class="btn btn-outline-primary rounded-pill px-4">
                        Изчисти
                    </a>
                </div>
            </form>
        </div>
    </div>

    <section class="mb-5">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
            <h2 class="fw-bold mb-0">Предстоящи</h2>
            <span class="badge rounded-pill bg-light text-dark border px-3 py-2">
                @Model.Upcoming.Count събития
            </span>
        </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            @if (Model.Upcoming == null || !Model.Upcoming.Any())
            {
                <div class="card-body p-4">
                    <p class="mb-0 text-muted">Няма предстоящи събития.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
