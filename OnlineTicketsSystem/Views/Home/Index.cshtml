                        {
                            if (Model.SelectedRegion == region)
                            {
                                <option value="@region" selected>@region</option>
                            }
                            else
                            {
                                <option value="@region">@region</option>
                            }
                        }
                    </select>

                    <select name="selectedCity" class="form-select">
                        <option value="">Избери град</option>
                        @foreach (var city in Model.CitiesInRegion)
                        {
                            if (Model.SelectedCity == city)
                            {
                                <option value="@city" selected>@city</option>
                            }
                            else
                            {
                                <option value="@city">@city</option>
                            }
                        }
                    </select>

                    <select name="dateRange" class="form-select">
                        <option value="">Предстоящи дати</option>
                        @if (Model.DateRange == "week")
                        {
                            <option value="week" selected>До 7 дни</option>
                        }
                        else
                        {
                            <option value="week">До 7 дни</option>
                        }

                        @if (Model.DateRange == "month")
                        {
                            <option value="month" selected>До 1 месец</option>
                        }
                        else
                        {
                            <option value="month">До 1 месец</option>
                        }
                    </select>

                    <select name="priceRange" class="form-select">
                        <option value="">Ценови диапазон</option>
                        @if (Model.PriceRange == "0-10")
                        {
                            <option value="0-10" selected>0 - 10</option>
                        }
                        else
                        {
                            <option value="0-10">0 - 10</option>
                        }

                        @if (Model.PriceRange == "10-20")
                        {
                            <option value="10-20" selected>10 - 20</option>
                        }
                        else
                        {
                            <option value="10-20">10 - 20</option>
                        }

                        @if (Model.PriceRange == "20+")
                        {
                            <option value="20+" selected>20+</option>
                        }
                        else
                        {
                            <option value="20+">20+</option>
                        }
