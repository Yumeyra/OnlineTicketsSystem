                        <p>Бързо откриваш събития и резервираш билетите си само с няколко стъпки.</p>
                    </div>
                </div>

                <div class="why__item">
                    <div class="why__icon">📍</div>
                    <div class="why__text">
                        <h3>Търсене по град и категория</h3>
                        <p>Филтрирай според местоположение, категория, дата и ценови диапазон.</p>
                    </div>
                </div>

                <div class="why__item">
                    <div class="why__icon">💜</div>
                    <div class="why__text">
                        <h3>Любими събития</h3>
                        <p>Запазвай интересните предложения и се връщай към тях по всяко време.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="cities">
        <div class="container">
            <h2 class="script-title">Популярни градове</h2>

            @if (Model.Cities.Any())
            {
                <div class="cities__grid">
                    @foreach (var city in Model.Cities)
                    {
                        <a asp-controller="Events"
                           asp-action="Index"
                           asp-route-selectedCity="@city"
                           class="city">
                            <div class="city__img" style="background-image:url('/images/cities/default-city.jpg');"></div>
                            <div class="city__name">@city</div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">Все още няма налични градове.</div>
            }
        </div>
    </section>
</div>

@section Scripts {
    <script>
        (function () {
            const slides = document.querySelectorAll(".hero__slide");
            if (!slides.length || slides.length === 1) return;

            let current = 0;

            setInterval(() => {
                slides[current].classList.remove("is-active");
                current = (current + 1) % slides.length;
                slides[current].classList.add("is-active");
            }, 4500);
        })();
    </script>
} *@

