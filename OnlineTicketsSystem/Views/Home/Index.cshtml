                </form>

                @if (Model.UpcomingEvents.Any())
                {
                    <div class="cards">
                        @foreach (var item in Model.UpcomingEvents)
                        {
                            <div class="event-card">
                                <div class="event-card__img"
                                     style="background-image:url('@(string.IsNullOrWhiteSpace(item.ImageUrl) ? "/images/no-image.png" : item.ImageUrl)')">
                                </div>

                                <div class="event-card__body">
                                    <span class="pill">@item.Category?.Name</span>

                                    <h3 class="event-card__title">@item.Title</h3>

                                    <div class="meta">
                                        <div class="meta__row"><strong>Град:</strong> @item.City</div>
                                        <div class="meta__row"><strong>Място:</strong> @item.Venue</div>
                                        <div class="meta__row"><strong>Дата:</strong> @item.Date.ToString("dd.MM.yyyy HH:mm")</div>
                                        <div class="meta__row"><strong>Цена:</strong> @item.Price.ToString("F2") EUR</div>
                                    </div>

                                    <a asp-controller="Events"
                                       asp-action="Details"
                                       asp-route-id="@item.Id"
