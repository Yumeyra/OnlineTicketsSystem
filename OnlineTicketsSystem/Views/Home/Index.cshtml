                                        Виж детайли
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        Няма намерени предстоящи събития по избраните филтри.
                    </div>
                }
            </section>
        </div>
    </section>

    <section class="why">
        <div class="container">
            <h2 class="script-title">Защо да избереш нашата платформа</h2>

            <div class="why__grid">
                <div class="why__item">
                    <div class="why__icon">🎟️</div>
                    <div class="why__text">
