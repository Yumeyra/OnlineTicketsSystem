@model List<OnlineTicketsSystem.Models.City>

@{
    ViewData["Title"] = "Всички градове";
}

<div class="container mt-4 mb-5">
    <div class="mb-4">
        <h1 class="fw-bold mb-2">Всички градове</h1>
        <p class="text-muted mb-0">Избери град и разгледай събитията в него.</p>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-light border rounded-4 shadow-sm p-4">
            <p class="mb-0 text-muted">Няма налични градове.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var city in Model.OrderBy(c => c.Name))
            {
                <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                    <div class="card h-100 border-0 shadow-sm rounded-4 city-list-card">
                        <div class="card-body d-flex flex-column p-4">
                            <h4 class="fw-bold mb-3">@city.Name</h4>

                            <p class="text-muted mb-4">
                                Разгледай наличните събития в @city.Name.
                            </p>

                            <div class="mt-auto">
                                <a asp-controller="Cities"
                                   asp-action="ByCity"
                                   asp-route-slug="@city.Slug"
                                   class="btn btn-primary rounded-3 px-4">
                                    Виж събития
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
