@model IEnumerable<OnlineTicketsSystem.Models.Event>

@{
    ViewData["Title"] = $"Събития в {ViewData["CityName"]}";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <h1 class="fw-bold mb-0">Събития в @ViewData["CityName"]</h1>
        <a asp-controller="Events" asp-action="Index" class="btn btn-outline-secondary rounded-3">
            ← Всички събития
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-light border rounded-4 shadow-sm p-4">
            <h4 class="fw-bold mb-2">Няма налични събития за този град.</h4>
            <p class="mb-0 text-muted">Можеш да разгледаш събитията в други градове.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var e in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 city-event-card overflow-hidden">
                        @if (!string.IsNullOrWhiteSpace(e.ImageUrl))
                        {
                            <img src="@e.ImageUrl"
                                 class="card-img-top"
                                 alt="@e.Title"
                                 style="height: 240px; object-fit: cover;" />
                        }
                        else
                        {
                            <img src="~/images/placeholder.jpg"
                                 class="card-img-top"
                                 alt="Няма снимка"
                                 style="height: 240px; object-fit: cover;" />
                        }

                        <div class="card-body d-flex flex-column p-4">
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                @if (!string.IsNullOrWhiteSpace(e.Category?.Name))
                                {
                                    <span class="badge bg-primary rounded-pill px-3 py-2">
                                        @e.Category.Name
                                    </span>
                                }

                                <span class="badge bg-light text-dark border rounded-pill px-3 py-2">
                                    @e.Date.ToString("dd.MM.yyyy")
                                </span>
                            </div>

                            <h4 class="fw-bold mb-3">@e.Title</h4>

                            <p class="mb-2">
                                <span class="fw-semibold">Място:</span> @e.Venue
                            </p>

                            <p class="mb-3">
                                <span class="fw-semibold">Град:</span> @e.City
                            </p>

                            <div class="mt-auto">
                                <a asp-controller="Events"
                                   asp-action="Details"
                                   asp-route-id="@e.Id"
                                   class="btn btn-primary rounded-3 px-4">
                                    Детайли
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
