@model IEnumerable<OnlineTicketsSystem.Models.Event>

@{
    var cityName = ViewData["CityName"]?.ToString() ?? "избрания град";
    var eventsList = Model?.ToList() ?? new List<OnlineTicketsSystem.Models.Event>();

    ViewData["Title"] = $"Събития в {cityName}";
}

<div class="container mt-4 mb-5">
    <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
        <div class="card-body p-4 p-lg-5">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <h1 class="fw-bold mb-2">Събития в @cityName</h1>
                    <p class="text-muted mb-3">
                        Разгледай всички налични събития в този град.
                    </p>

                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge rounded-pill bg-light text-dark border px-3 py-2">
                            Град: @cityName
                        </span>
                        <span class="badge rounded-pill bg-light text-dark border px-3 py-2">
                            Намерени събития: @eventsList.Count
                        </span>
                    </div>
                </div>

                <div>
                    <a asp-controller="Events"
                       asp-action="Index"
                       class="btn btn-outline-primary rounded-pill px-4">
                        ← Всички събития
                    </a>
                </div>
            </div>
        </div>
    </div>

    @if (!eventsList.Any())
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5 text-center">
                <h4 class="fw-bold mb-2">Няма налични събития за @cityName.</h4>
                <p class="text-muted mb-4">Можеш да разгледаш събитията в други градове или всички събития.</p>

                <a asp-controller="Events"
                   asp-action="Index"
                   class="btn btn-primary rounded-pill px-4">
                    Виж всички събития
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4 justify-content-center">
            @foreach (var e in eventsList)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 city-event-card overflow-hidden">
                        @if (!string.IsNullOrWhiteSpace(e.ImageUrl))
                        {
                            <img src="@e.ImageUrl"
                                 class="card-img-top"
                                 alt="@e.Title"
                                 style="height: 250px; object-fit: cover;" />
                        }
                        else
                        {
                            <img src="~/images/placeholder.jpg"
                                 class="card-img-top"
                                 alt="Няма снимка"
                                 style="height: 250px; object-fit: cover;" />
                        }

                        <div class="card-body d-flex flex-column p-4">
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                @if (!string.IsNullOrWhiteSpace(e.Category?.Name))
                                {
                                    <span class="badge bg-primary rounded-pill px-3 py-2">
                                        @e.Category.Name
                                    </span>
                                }

                                <span class="badge bg-light text-dark border rounded-pill px-3 py-2">
                                    @e.Date.ToString("dd.MM.yyyy")
                                </span>
                            </div>

                            <h4 class="fw-bold mb-3">@e.Title</h4>

                            <p class="mb-2">
                                <span class="fw-semibold">Място:</span> @e.Venue
                            </p>

                            <p class="mb-4">
                                <span class="fw-semibold">Град:</span> @e.City
                            </p>

                            <div class="mt-auto">
                                <a asp-controller="Events"
                                   asp-action="Details"
                                   asp-route-id="@e.Id"
                                   class="btn btn-primary rounded-3 px-4">
                                    Детайли
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>